APP_NAME=MedVoyage
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
APP_PORT=8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=medvoyage
DB_USERNAME=medvoyage
DB_PASSWORD=secret

# ── Session / Cache / Queue ────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=database
CACHE_PREFIX=medvoyage_

QUEUE_CONNECTION=database

# ── File Storage ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Facility Settings ──────────────────────────────────────────────────────────
FACILITY_TIMEZONE=America/New_York
FACILITY_NAME="MedVoyage Medical Center"

# ── Seat Hold Settings ─────────────────────────────────────────────────────────
SEAT_HOLD_MINUTES=10
WAITLIST_OFFER_MINUTES=10

# ── Broadcasting (Laravel Reverb) ─────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=medvoyage
REVERB_APP_KEY=medvoyage-key
REVERB_APP_SECRET=medvoyage-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Dusk (Browser Tests) ───────────────────────────────────────────────────────
DUSK_DRIVER_URL=http://chrome:4444/wd/hub

# ── Host Port Overrides (optional) ────────────────────────────────────────────
# APP_PORT=8000
# DB_PORT=5432

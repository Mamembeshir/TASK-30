APP_NAME=MedVoyage
APP_ENV=testing
APP_KEY=base64:0Gty/tDXg4GD04X+Ge5REMGBxPLZRZAQ64dNoEZFV9A=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── PostgreSQL (test database) ─────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=medvoyage_test
DB_USERNAME=medvoyage
DB_PASSWORD=secret

# ── Session / Cache / Queue ────────────────────────────────────────────────────
SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=array

QUEUE_CONNECTION=sync

# ── File Storage ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Facility Settings ──────────────────────────────────────────────────────────
FACILITY_TIMEZONE=America/New_York
FACILITY_NAME="MedVoyage Medical Center"

# ── Seat Hold Settings ─────────────────────────────────────────────────────────
SEAT_HOLD_MINUTES=10
WAITLIST_OFFER_MINUTES=10

# ── Idempotency ────────────────────────────────────────────────────────────────
IDEMPOTENCY_TTL_HOURS=24

MAIL_MAILER=array
BROADCAST_CONNECTION=log
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=4
